# ── Server ──────────────────────────────────────────────────────────
CV_HOST=127.0.0.1
CV_PORT=8765
CV_ENVIRONMENT=development
CV_LOG_LEVEL=INFO
CV_CORS_ORIGINS=["http://localhost:5173"]

# ── Storage ─────────────────────────────────────────────────────────
CV_STORAGE_DIR=./storage
CV_DATABASE_URL=sqlite:///./storage/cv_builder.db
CV_UPLOAD_DIR=./storage/uploads
CV_CV_EXPORT_DIR=./storage/cv_exports
CV_CL_EXPORT_DIR=./storage/cl_exports
CV_RAW_HTML_DIR=./storage/raw_html
CV_PROMPTS_DIR=./storage/prompts
CV_TEMPLATES_DIR=./storage/templates
CV_LOG_DIR=./storage/logs

# ── Security ────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CV_MASTER_KEY=dev-only-please-rotate-in-production

# ── LLM Providers ──────────────────────────────────────────────────
# Primary provider: tokenrouter (OpenAI-compatible)
# Other providers supported: openai, anthropic, ollama
# Provider config is loaded from: configs/llm_providers.json
# Get your tokenrouter key at: https://tokenrouter.com
TOKENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── File upload limits ──────────────────────────────────────────────
CV_MAX_UPLOAD_BYTES=10485760

# ── Scraping ────────────────────────────────────────────────────────
CV_SCRAPER_RESPECT_ROBOTS=true
CV_SCRAPER_REQUEST_TIMEOUT=30
CV_SCRAPER_CACHE_TTL_HOURS=24
